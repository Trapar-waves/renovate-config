{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Trapar-waves template repos — shared Renovate preset",
  "extends": ["config:best-practices"],
  "ignorePresets": [
    ":pinDevDependencies",
    "helpers:pinGitHubActionDigests",
    "docker:pinDigests",
    "security:minimumReleaseAgeNpm"
  ],
  "rangeStrategy": "bump",
  "minimumReleaseAge": "1 day",
  "internalChecksFilter": "flexible",
  "packageRules": [
    {
      "description": "Group React runtime and types",
      "groupName": "react",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ]
    },
    {
      "description": "Group Rsbuild toolchain",
      "groupName": "rsbuild",
      "matchPackageNames": ["/@rsbuild/*/", "/@rsdoctor/*/"]
    },
    {
      "description": "Group internal Trapar-waves packages",
      "groupName": "trapar-waves templates",
      "matchPackageNames": ["/@trapar-waves/*/"]
    }
  ]
}
